# Shared
NODE_ENV=development

# PostgreSQL
DATABASE_URL="postgresql://nationchain:nationchain@localhost:5432/nationchain?schema=public"

# Backend
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_OR_ALCHEMY_KEY
ORACLE_PRIVATE_KEY=0xYOUR_BACKEND_ORACLE_PRIVATE_KEY
GAME_CORE_ADDRESS=0x0000000000000000000000000000000000000000
WAR_SYSTEM_ADDRESS=0x0000000000000000000000000000000000000000
NEWSAPI_KEY=your_newsapi_key
GNEWS_API_KEY=your_gnews_key
OPENAI_API_KEY=sk-your_openai_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Contracts
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
LOCAL_RPC_URL=http://127.0.0.1:8545
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
BACKEND_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000
BUILDING_METADATA_BASE_URI=https://nationchain.game/metadata/buildings
ETHERSCAN_API_KEY=your_etherscan_key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_OR_ALCHEMY_KEY
NEXT_PUBLIC_NATION_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_GOV_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_COUNTRY_NFT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BUILDING_NFT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_GAME_CORE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_WAR_SYSTEM_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DIPLOMACY_SYSTEM_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
